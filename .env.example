# Copy this file to .env and update the values

# ── Database (used by Docker Compose) ────────────────────────────────────────
POSTGRES_DB=familyfit
POSTGRES_USER=familyfit
POSTGRES_PASSWORD=familyfit

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://familyfit:familyfit@db:5432/familyfit
SECRET_KEY=supersecretkey-change-in-production-use-256-bit-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEBUG=false

# Public URL used inside invite emails / links and OAuth redirect
APP_URL=http://localhost:5173

# ── Google OAuth 2.0 (optional — leave blank to hide the Google button) ───────
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
#   1. Create OAuth 2.0 Client ID (Web application)
#   2. Add http://localhost:8000/api/v1/auth/google/callback to Authorized redirect URIs
#   3. Paste Client ID and Client Secret below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── SMTP Email (optional — leave blank to display invite link in UI instead) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# Example for Gmail (use an App Password, not your account password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=you@gmail.com

# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxxxx
# SMTP_FROM=noreply@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
